# ============================================================================
# /etc/briar/secrets.env  — example matching examples/multi_company.yaml
# ============================================================================
#
# Mode 0600, owner root:briar. systemd reads it via EnvironmentFile=.
#
# Variable naming follows two patterns:
#   - Workspace-wide:  TOKEN_NAME (no per-tenant segment)
#   - Per-company:     PROVIDER_<COMPANY>_NAME — where <COMPANY> is the
#                      company key from the runbook YAML, uppercased,
#                      hyphens turned into underscores.
#
# This file demonstrates EVERY variable Briar reads. Copy what you need;
# unset variables are silently ignored by the EnvFile store.
# ============================================================================


# ─── workspace-wide credentials ─────────────────────────────────────────────

# GitHub PAT — used by GithubProvider + GithubIssuesTracker. Workspace-wide
# because GitHub PATs can carry scopes across orgs; per-company isolation
# isn't a thing.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres DSN for the `postgres` knowledge store. Optional; without it
# the file backend (./knowledge/<company>.md) is used. bitspark in the
# example runbook requires this to be set.
BRIAR_DATABASE_URL=postgresql://briar_kb:xxx@db.internal:5432/briar?sslmode=require


# ─── LLM auth (only needed if you run `briar agent`) ────────────────────────

# Anthropic — the default LLM provider. Either OAuth (subscription billing)
# or a flat API key works.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-api03-xxx                # alternative auth

# Alternative LLM providers (require the matching pip extra):
# OPENAI_API_KEY=sk-xxx                             # pip install briar-cli[openai]
# GEMINI_API_KEY=AIza-xxx                           # pip install briar-cli[gemini]
# (Bedrock uses the ambient AWS credential chain — no separate key.)


# ─── notification fan-out (scheduler failure alerts) ────────────────────────

# Comma-separated list of sink kinds. Empty disables notifications.
# Available: telegram, slack, email, pagerduty
BRIAR_NOTIFY_SINKS=telegram,slack,pagerduty

# Telegram (workspace-wide bot token + per-company chat IDs below).
TELEGRAM_BOT_TOKEN=1234567890:AAA-xxx

# SMTP for the email sink — only needed if `email` is in BRIAR_NOTIFY_SINKS.
# Per-company recipients live in each company's section below.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=briar@example.com
# SMTP_PASSWORD=xxx
# SMTP_STARTTLS=true
# EMAIL_FROM=briar@example.com


# ─── credential-store backend (briar secrets doctor) ────────────────────────

# Only relevant when running `briar secrets doctor --store <kind>`. The
# default (envfile) reads from this file directly; the others need their
# own setup:
# - aws-secretsmanager: uses ambient AWS creds, reads /briar/<NAME> secrets.
# - ssm:                uses ambient AWS creds, reads /briar/<NAME> params.
# - vault:              VAULT_ADDR=https://vault.example.com:8200 + VAULT_TOKEN.

# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=hvs.xxx


# ============================================================================
# acme — GitHub + AWS + Jira + Telegram
# ============================================================================

# AWS STS triplet — refresh via `aws configure export-credentials --profile acme`.
AWS_ACME_ACCESS_KEY_ID=ASIA-xxx
AWS_ACME_SECRET_ACCESS_KEY=xxx
AWS_ACME_SESSION_TOKEN=IQoJ-xxx
AWS_ACME_REGION=us-east-1

# Jira Cloud — URL + bot email + Atlassian API token.
JIRA_ACME_URL=https://acme.atlassian.net
JIRA_ACME_EMAIL=ops@acme.example
JIRA_ACME_TOKEN=ATATT-xxx

# Telegram channel for acme failure alerts.
TELEGRAM_ACME_CHAT_ID=-1001234567890


# ============================================================================
# bitspark — Bitbucket Cloud + AWS + Linear + Slack
# ============================================================================

# Bitbucket Cloud app password (NOT the user's account password).
# Generate at https://bitbucket.org/account/settings/app-passwords/.
BITBUCKET_BITSPARK_USERNAME=bitspark-bot
BITBUCKET_BITSPARK_APP_PASSWORD=ATBB-xxx
BITBUCKET_BITSPARK_WORKSPACE=bitspark

# AWS for the same company, different region than acme.
AWS_BITSPARK_ACCESS_KEY_ID=ASIA-yyy
AWS_BITSPARK_SECRET_ACCESS_KEY=yyy
AWS_BITSPARK_SESSION_TOKEN=IQoJ-yyy
AWS_BITSPARK_REGION=us-west-2

# Linear API key — NO 'Bearer' prefix (Linear quirk).
LINEAR_BITSPARK_TOKEN=lin_api_xxx

# Slack incoming-webhook URL is itself the credential (no separate token).
SLACK_BITSPARK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxx


# ============================================================================
# datacore — GitHub + GCP + Bitbucket Issues + PagerDuty
# ============================================================================

# GITHUB_TOKEN already declared workspace-wide — no per-company copy needed.

# Bitbucket Cloud — legacy workspace for the tracker only.
BITBUCKET_DATACORE_USERNAME=datacore-bot
BITBUCKET_DATACORE_APP_PASSWORD=ATBB-yyy
BITBUCKET_DATACORE_WORKSPACE=datacore-legacy

# GCP — Application Default Credentials. Either a service-account JSON
# path here, OR `gcloud auth application-default login` on the dev box.
GOOGLE_APPLICATION_CREDENTIALS=/etc/briar/gcp-datacore-sa.json

# PagerDuty Events API v2 integration key for datacore failure alerts.
PAGERDUTY_DATACORE_ROUTING_KEY=R0CMxx
