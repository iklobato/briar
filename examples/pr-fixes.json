{
  "version": 1,
  "llm_models": [
    {
      "key": "prfix-model",
      "name": "prfix-claude-sonnet-4-6",
      "provider_key": "anthropic",
      "display_name": "claude-sonnet-4-6",
      "default_params": {
        "temperature": 0.1
      }
    }
  ],
  "sources": [
    {
      "key": "prfix-pr-comments",
      "name": "prfix-pr-comments",
      "kind": "github",
      "config": {
        "owner": "your-org",
        "repo": "your-repo",
        "fetch": "pr_review_comments",
        "include": "unresolved"
      },
      "credential_binding": {
        "kind": "oauth_connection",
        "provider": "github"
      }
    }
  ],
  "tools": [
    {
      "key": "prfix-gh-push",
      "name": "prfix-gh-push",
      "description": "Commit a code change and push it to the PR branch",
      "implementation_ref": "tools_github.push_commit",
      "side_effect": "mutate",
      "credential_binding": {
        "kind": "oauth_connection",
        "provider": "github"
      }
    },
    {
      "key": "prfix-gh-reply",
      "name": "prfix-gh-reply",
      "description": "Reply to a review comment + mark it resolved",
      "implementation_ref": "tools_github.reply_review_comment",
      "side_effect": "mutate",
      "credential_binding": {
        "kind": "oauth_connection",
        "provider": "github"
      }
    }
  ],
  "agents": [
    {
      "key": "prfix-fixer",
      "name": "prfix-fixer",
      "role": "PR fix engineer",
      "goal": "Address each unresolved review comment with a minimal, correct fix.",
      "backstory": "You triage open review comments on PRs in your-org/your-repo, apply the fix locally, push a follow-up commit, and reply to the comment.",
      "llm_model_key": "prfix-model",
      "tool_keys": [
        "prfix-gh-push",
        "prfix-gh-reply"
      ],
      "source_keys": [
        "prfix-pr-comments"
      ],
      "max_iter": 12
    }
  ],
  "workflows": [
    {
      "key": "prfix-workflow",
      "name": "prfix-workflow",
      "description": "PR-fix pipeline for your-org/your-repo",
      "graph": {
        "process": "sequential",
        "entry": "fix",
        "nodes": [
          {
            "id": "fix",
            "kind": "agent",
            "agent_key": "prfix-fixer",
            "prompt": "Read each unresolved review comment, decide the smallest fix, push a commit, and reply marking it resolved.",
            "next": null
          }
        ]
      }
    }
  ],
  "triggers": [
    {
      "key": "prfix-trigger",
      "name": "prfix-trigger",
      "kind": "github_webhook",
      "workflow_key": "prfix-workflow",
      "filter_rules": {
        "events": [
          "pull_request_review_comment.created"
        ]
      },
      "payload_to_context_mapping": {
        "pr_number": "$.pull_request.number",
        "comment_body": "$.comment.body",
        "comment_path": "$.comment.path"
      },
      "is_enabled": true
    }
  ]
}